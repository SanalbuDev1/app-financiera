# =============================================
# Variables de entorno requeridas para producción
# Copiar a .env y llenar con valores reales (NO commitear .env)
# Estas mismas variables van como GitHub Secrets para el pipeline
# =============================================

# --- Base de datos (Neon PostgreSQL) ---
SPRING_R2DBC_URL=r2dbc:postgresql://ep-xxxxx.us-east-2.aws.neon.tech:5432/finanzas_db?sslmode=require
SPRING_R2DBC_USERNAME=neon_user
SPRING_R2DBC_PASSWORD=neon_password_here

# --- JWT ---
APP_JWT_SECRET=clave-secreta-aleatoria-minimo-64-caracteres-aqui

# --- CORS (dominio del frontend) ---
APP_CORS_ALLOWED_ORIGINS=https://mi-app.azurestaticapps.net

# --- Azure Container Registry (solo para CI/CD) ---
AZURE_CREDENTIALS={"clientId":"...","clientSecret":"...","subscriptionId":"...","tenantId":"..."}
ACR_LOGIN_SERVER=finanzasacr.azurecr.io
ACR_USERNAME=finanzasacr
ACR_PASSWORD=password_del_registry

# --- Azure Container Apps (solo para CI/CD) ---
AZURE_RESOURCE_GROUP=rg-finanzas
AZURE_CONTAINER_APP_NAME=finanzas-app
AZURE_CONTAINER_ENV=finanzas-env
