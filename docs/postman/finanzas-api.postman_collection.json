{
  "info": {
    "name": "Finanzas Personales API",
    "_postman_id": "finanzas-personales-2026",
    "description": "Colección completa de endpoints del backend de Finanzas Personales.\n\n**Flujo de uso:**\n1. Ejecutar **Login** (carpeta Auth) → el token JWT se guarda automáticamente en la variable `token`\n2. Todos los demás requests lo usan vía `Authorization: Bearer {{token}}`\n\n**Variables de entorno requeridas:**\n- `baseUrl` → http://localhost:9000\n- `token` → se auto-llena al hacer login",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:9000", "type": "string" },
    { "key": "token", "value": "", "type": "string" },
    { "key": "debtId", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/health", "host": ["{{baseUrl}}"], "path": ["api", "health"] }
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login - Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) {",
                  "    pm.collectionVariables.set('token', json.token);",
                  "    console.log('Token guardado:', json.token.substring(0, 30) + '...');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@financiera.com\",\n  \"password\": \"admin123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] }
          }
        },
        {
          "name": "Login - User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) {",
                  "    pm.collectionVariables.set('token', json.token);",
                  "    console.log('Token guardado:', json.token.substring(0, 30) + '...');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@financiera.com\",\n  \"password\": \"user123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] }
          }
        },
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"nuevo@ejemplo.com\",\n  \"password\": \"password123\",\n  \"name\": \"Usuario Nuevo\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api", "auth", "register"] }
          }
        }
      ]
    },
    {
      "name": "Transactions",
      "item": [
        {
          "name": "Listar transacciones (paginado)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/transactions?page=0&size=15",
              "host": ["{{baseUrl}}"],
              "path": ["api", "transactions"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "15" },
                { "key": "from", "value": "", "disabled": true },
                { "key": "to", "value": "", "disabled": true },
                { "key": "type", "value": "expense", "disabled": true },
                { "key": "category", "value": "food", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Listar todas las transacciones",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/transactions/all", "host": ["{{baseUrl}}"], "path": ["api", "transactions", "all"] }
          }
        },
        {
          "name": "Resumen financiero",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/transactions/summary?month=5&year=2026",
              "host": ["{{baseUrl}}"],
              "path": ["api", "transactions", "summary"],
              "query": [
                { "key": "month", "value": "5" },
                { "key": "year", "value": "2026" }
              ]
            }
          }
        },
        {
          "name": "Crear transacción",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"description\": \"Supermercado Éxito\",\n  \"amount\": 150000,\n  \"category\": \"food\",\n  \"type\": \"expense\",\n  \"transactionDate\": \"2026-05-17\",\n  \"notes\": \"Compra semanal\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/transactions", "host": ["{{baseUrl}}"], "path": ["api", "transactions"] }
          }
        },
        {
          "name": "Actualizar transacción",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"description\": \"Supermercado Éxito - Actualizado\",\n  \"amount\": 175000,\n  \"category\": \"food\",\n  \"type\": \"expense\",\n  \"transactionDate\": \"2026-05-17\",\n  \"notes\": \"Monto corregido\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/transactions/:id", "host": ["{{baseUrl}}"], "path": ["api", "transactions", ":id"], "variable": [{ "key": "id", "value": "REEMPLAZAR_CON_ID" }] }
          }
        },
        {
          "name": "Eliminar transacción",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/transactions/:id", "host": ["{{baseUrl}}"], "path": ["api", "transactions", ":id"], "variable": [{ "key": "id", "value": "REEMPLAZAR_CON_ID" }] }
          }
        }
      ]
    },
    {
      "name": "Deudas",
      "item": [
        {
          "name": "Resumen de deudas",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/debts/summary", "host": ["{{baseUrl}}"], "path": ["api", "debts", "summary"] }
          }
        },
        {
          "name": "Listar deudas",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/debts",
              "host": ["{{baseUrl}}"],
              "path": ["api", "debts"],
              "query": [
                { "key": "status", "value": "active", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Listar deudas activas",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/debts?status=active",
              "host": ["{{baseUrl}}"],
              "path": ["api", "debts"],
              "query": [{ "key": "status", "value": "active" }]
            }
          }
        },
        {
          "name": "Obtener detalle de deuda",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/debts/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "debts", ":id"],
              "variable": [{ "key": "id", "value": "{{debtId}}" }]
            }
          }
        },
